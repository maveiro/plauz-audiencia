# Supabase
# Encontrados em: Supabase Dashboard > Project Settings > API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
# Mesmos valores de SUPABASE_URL/SUPABASE_ANON_KEY acima, mas com o prefixo
# NEXT_PUBLIC_ pra ficarem disponíveis no bundle do browser — usados pelo
# botão "Entrar com Google" (lib/supabase/client.ts). Seguro expor: a anon
# key não dá acesso a nenhuma tabela (RLS habilitado, zero policies), só à
# API de Auth.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Domínio do Google Workspace autorizado a logar (ver app/auth/callback/route.ts
# e middleware). Opcional — se vazio, o código usa "plauz.com.br" como
# padrão (falha fechado: nunca vira "vazio permite qualquer domínio").
ALLOWED_EMAIL_DOMAIN=plauz.com.br

# Opcional. Connection string do Postgres — não é usada pela aplicação, só para
# acesso direto via psql/Supabase CLI (debug, queries ad-hoc). Encontrada em:
# Project Settings > Database > Connection string (URI). Faça percent-encode
# na senha se ela tiver caracteres especiais.
DATABASE_URL=

# Google Sheets API (service account — somente leitura)
# Encontrados em: Google Cloud Console > IAM & Admin > Service Accounts > Keys (JSON)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Cole a private_key do JSON da service account. Mantenha as quebras de linha como "\n" (uma única linha aqui).
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Nome do bucket no Supabase Storage usado para uploads de CSV/XLS.
SUPABASE_STORAGE_BUCKET=uploads-fontes

# Segredo compartilhado para autenticar chamadas do Vercel Cron à rota de sync.
CRON_SECRET=

# Chave da API da Anthropic (Claude), usada apenas server-side pelo botão
# "Resolver com IA" em /revisao (lib/geo/aiResolveGeografia.ts) para tratar
# automaticamente casos simples (apelidos, abreviações) que a normalização
# geográfica determinística deixou pendentes. Gerada em
# console.anthropic.com/settings/keys.
ANTHROPIC_API_KEY=
